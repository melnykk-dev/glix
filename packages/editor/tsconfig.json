{
    "compilerOptions": {
        "target": "ESNext",
        "useDefineForClassFields": true,
        "lib": [
            "DOM",
            "DOM.Iterable",
            "ESNext"
        ],
        "allowJs": false,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "module": "ESNext",
        "moduleResolution": "Node",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "react-jsx",
        "baseUrl": ".",
        "paths": {
            "@glix/runtime/*": [
                "../runtime/*"
            ],
            "@glix/shared/*": [
                "../shared/*"
            ],
            "@glix/runtime": [
                "../runtime/index.ts"
            ],
            "@glix/shared": [
                "../shared/index.ts"
            ]
        }
    },
    "include": [
        "src"
    ]
}