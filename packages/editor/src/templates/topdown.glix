            "sprite": { "textureId": "", "tintColor": "#475569", "width": 1, "height": 1, "pivotX": 0.5, "pivotY": 0.5 },
            "rigidBody": { "type": "static", "gravityScale": 0, "linearDamping": 0, "angularDamping": 0, "fixedRotation": true },
            "boxCollider": { "width": 1, "height": 1, "offsetX": 0, "offsetY": 0, "isSensor": false, "restitution": 0, "friction": 0.1 }
